# ============================================================================
# E-Syrians API — environment template
# ============================================================================
#
# Copy this file to `.env` (gitignored) and fill in real values. Every value
# below either has a sensible default (where shown) or needs your input.
#
# Groups marked **REQUIRED** must be filled before the app boots cleanly.
# Groups marked **OPTIONAL** can be left empty and the relevant feature
# degrades gracefully (logs a warning, falls back to a no-op, etc.).
#
# When in doubt: search the codebase for `env('VARNAME')` to see exactly
# where each value is read and what it gates.
# ============================================================================


# ----------------------------------------------------------------------------
# REQUIRED — App identity + URLs
# ----------------------------------------------------------------------------

# URL of the Next.js frontend (e-syrians-app). Used by:
#   - Email verification + password-reset links (the API mints the URL
#     pointing at the frontend, which then POSTs back to the API).
#   - Apple Sign-In redirect target (web flow).
# Production: https://www.e-syrians.com
# Local dev:  http://localhost:3000
FRONTEND_URL=""

APP_NAME=E-SYRIANS
APP_ENV=production
# Generate with `php artisan key:generate`. Stored as `base64:…` —
# never reuse keys across environments.
APP_KEY=""
APP_DEBUG=false
APP_TIMEZONE=UTC

# Bare host (no scheme, no trailing slash) used to build SESSION_DOMAIN
# below. Set to e.g. `e-syrians.com` in production so cookies are
# shared across `api.e-syrians.com` and `www.e-syrians.com`. Leaving
# this empty makes `SESSION_DOMAIN` resolve to a literal `.`, which
# breaks sessions silently.
APP_DOMAIN=""
APP_URL="http://api.e-syrians.com"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US


# ----------------------------------------------------------------------------
# REQUIRED — Database
# ----------------------------------------------------------------------------

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=""

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.${APP_DOMAIN}

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=""
REDIS_PORT=6379


# ----------------------------------------------------------------------------
# REQUIRED — Mail (transactional email — verification, reset, etc.)
# ----------------------------------------------------------------------------

# Production: use `resend` and fill RESEND_KEY below. Local dev: `array`
# captures emails into memory (visible via Laravel's `MailFake`).
MAIL_MAILER=array
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@notifications.e-syrians.com"
MAIL_FROM_NAME="${APP_NAME}"

# Resend API key (https://resend.com/api-keys). Required if MAIL_MAILER=resend.
RESEND_KEY=""


# ----------------------------------------------------------------------------
# REQUIRED FOR FILE UPLOADS — AWS S3 (avatars + future attachments)
# ----------------------------------------------------------------------------

# Create an IAM user with PutObject/GetObject/DeleteObject on your bucket.
# `AWS_BUCKET` is the bucket NAME (not ARN). `AWS_DEFAULT_REGION` is the
# region the bucket lives in (e.g. `us-east-1`, `eu-west-1`).
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_DEFAULT_REGION=""
AWS_BUCKET=""
AWS_USE_PATH_STYLE_ENDPOINT=""


# ----------------------------------------------------------------------------
# REQUIRED — Social sign-in (token audience verification)
# ----------------------------------------------------------------------------
#
# This API acts as a **token verifier**, not an OAuth client. The
# OAuth handshakes happen in the web app (Next.js NextAuth) and on
# mobile (native SDKs) — the resulting identity tokens are POSTed to
# `/users/login/social`, and the API only checks the audience claim
# against these ids.
#
# Consequently: NO GOOGLE_CLIENT_SECRET, NO GOOGLE_REDIRECT_URI,
# NO APPLE_CLIENT_SECRET, NO APPLE_REDIRECT_URI on this side. Those
# belong to whichever component actually runs the OAuth flow.

# Google — the public OAuth 2.0 client id (WEB type) from Google Cloud
# Console → APIs & Services → Credentials. Used as the expected `aud`
# claim when verifying Google ID tokens. Same value as web's
# AUTH_GOOGLE_ID and mobile's EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID.
GOOGLE_CLIENT_ID=""

# Apple — TWO ids because iOS and web use different Apple identifiers:
#
# APPLE_CLIENT_ID:
#   The MOBILE bundle id (com.esyrians.app). Native iOS Sign In with
#   Apple mints tokens with the bundle id as the audience — this value
#   is what we check the token against.
#
# APPLE_WEB_CLIENT_ID:
#   The Services ID registered for the WEB popup flow (e.g.
#   com.esyrians.app.web — Services IDs use the dotted form Apple
#   requires). The web app's NextAuth issues tokens with this
#   audience; must match NEXT_PUBLIC_APPLE_CLIENT_ID on the web side.
APPLE_CLIENT_ID=""
APPLE_WEB_CLIENT_ID=""


# ----------------------------------------------------------------------------
# REQUIRED — reCAPTCHA Enterprise (anti-spam on sensitive writes)
# ----------------------------------------------------------------------------

# reCAPTCHA Enterprise — verified via the Assessments API. The legacy
# RECAPTCHA_SECRET (v3 classic siteverify) is no longer used.
#
#   RECAPTCHA_PROJECT_ID  GCP project ID hosting the Enterprise key.
#   RECAPTCHA_API_KEY     Credentials → API key, with the reCAPTCHA
#                         Enterprise API enabled. Restrict the key to
#                         only that API.
#   RECAPTCHA_SITE_KEY    Site key from Security → reCAPTCHA Enterprise.
#                         Must match mobile's EXPO_PUBLIC_RECAPTCHA_SITE_KEY
#                         and web's NEXT_PUBLIC_RECAPTCHA.
#   RECAPTCHA_MIN_SCORE   Optional. Defaults to 0.7. Lower if real users
#                         are getting blocked; raise if bots leak through.
RECAPTCHA_PROJECT_ID=""
RECAPTCHA_API_KEY=""
RECAPTCHA_SITE_KEY=""
RECAPTCHA_MIN_SCORE=0.7


# ----------------------------------------------------------------------------
# REQUIRED FOR PUSH — OneSignal (server-side credentials)
# ----------------------------------------------------------------------------

# OneSignal push notifications — server-side credentials. The mobile
# bundle reads its own EXPO_PUBLIC_ONESIGNAL_APP_ID; the REST API key
# below is SERVER-SIDE only and must never be bundled into the JS or
# exposed to the browser.
#
# Both from the OneSignal dashboard → Settings → Keys & IDs. Modern
# OneSignal keys are prefixed `os_v2_…`; the service auto-detects the
# format (see `OneSignalService::isV2Key`).
#
# ONESIGNAL_APP_ID is the SAME value as mobile's EXPO_PUBLIC_ONESIGNAL_APP_ID.
# ONESIGNAL_REST_API_KEY is the **server-side** key — never the mobile key.
ONESIGNAL_APP_ID=""
ONESIGNAL_REST_API_KEY=""


# ----------------------------------------------------------------------------
# OPTIONAL — Operational
# ----------------------------------------------------------------------------

# Laravel Nightwatch (paid Laravel monitoring service). Leave token empty
# to skip enrollment. https://nightwatch.laravel.com
NIGHTWATCH_TOKEN=""
NIGHTWATCH_ENABLED=true

OCTANE_SERVER=frankenphp
OCTANE_HTTPS=true
OCTANE_WORKERS=auto
OCTANE_MAX_REQUESTS=500

# Comma-separated list of Horizon admin emails — only these accounts
# can access /horizon in production. Leave blank to allow only the
# default fjobeir@gmail.com.
HORIZON_ALLOWED_EMAILS="fjobeir@gmail.com"

# Inbox the SuspiciousActivity webhook fires alerts at.
ADMIN_NOTIFICATION_EMAIL=""

# Shared secret for internal/admin-only webhooks (e.g. the suspicious
# activity webhook). Generate with `openssl rand -hex 32`. Required only
# when calling internal admin endpoints from a trusted external job.
INTERNAL_API_KEY=""


# ----------------------------------------------------------------------------
# OPTIONAL — BigQuery (analytics audit pipeline)
# ----------------------------------------------------------------------------

# When ENABLED, profile changes / poll votes / poll audience rules get
# streamed to BigQuery for analytics. CREDENTIALS is the absolute path
# to a service-account JSON file (or the JSON itself, depending on
# config). Set ENABLED=false to no-op the whole pipeline.
BIGQUERY_ENABLED=false
BIGQUERY_PROJECT_ID=""
BIGQUERY_DATASET="e_syrians_audit"
BIGQUERY_CREDENTIALS=""
