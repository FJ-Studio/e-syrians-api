FRONTEND_URL=""
APP_NAME=E-SYRIANS
APP_ENV=production
APP_KEY=""
APP_DEBUG=false
APP_TIMEZONE=UTC
# Bare host (no scheme, no trailing slash) used to build SESSION_DOMAIN
# below. Set to e.g. `e-syrians.com` in production so cookies are
# shared across `api.e-syrians.com` and `www.e-syrians.com`. Leaving
# this empty makes `SESSION_DOMAIN` resolve to a literal `.`, which
# breaks sessions silently.
APP_DOMAIN=""
APP_URL="http://api.e-syrians.com"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=""

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.${APP_DOMAIN}

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=""
REDIS_PORT=6379

MAIL_MAILER=array
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@notifications.e-syrians.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_DEFAULT_REGION=""
AWS_BUCKET=""
AWS_USE_PATH_STYLE_ENDPOINT=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

APPLE_CLIENT_ID=""
APPLE_WEB_CLIENT_ID=""

# reCAPTCHA Enterprise — verified via the Assessments API. The legacy
# RECAPTCHA_SECRET (v3 classic siteverify) is no longer used.
#
#   RECAPTCHA_PROJECT_ID  GCP project ID hosting the Enterprise key.
#   RECAPTCHA_API_KEY     Credentials → API key, with the reCAPTCHA
#                         Enterprise API enabled. Restrict the key to
#                         only that API.
#   RECAPTCHA_SITE_KEY    Site key from Security → reCAPTCHA Enterprise.
#                         Must match mobile's EXPO_PUBLIC_RECAPTCHA_SITE_KEY
#                         and web's NEXT_PUBLIC_RECAPTCHA_SITE_KEY.
#   RECAPTCHA_MIN_SCORE   Optional. Defaults to 0.7. Lower if real users
#                         are getting blocked; raise if bots leak through.
RECAPTCHA_PROJECT_ID=""
RECAPTCHA_API_KEY=""
RECAPTCHA_SITE_KEY=""
RECAPTCHA_MIN_SCORE=0.7
RESEND_KEY=""

NIGHTWATCH_TOKEN=""
NIGHTWATCH_ENABLED=true

OCTANE_SERVER=frankenphp
OCTANE_HTTPS=true
OCTANE_WORKERS=auto
OCTANE_MAX_REQUESTS=500

HORIZON_ALLOWED_EMAILS="fjobeir@gmail.com"
ADMIN_NOTIFICATION_EMAIL=""
INTERNAL_API_KEY=""

BIGQUERY_ENABLED=false
BIGQUERY_PROJECT_ID=""
BIGQUERY_DATASET="e_syrians_audit"
BIGQUERY_CREDENTIALS=""
