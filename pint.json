{
    "preset": "psr12",
    "rules": {
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "length"
        },
        "global_namespace_import": {
            "import_classes": true,
            "import_constants": true,
            "import_functions": true
        },
        "fully_qualified_strict_types": {
            "import_symbols": true
        },
        "no_superfluous_phpdoc_tags": {
            "allow_mixed": true,
            "allow_unused_params": true
        }
    }
}
